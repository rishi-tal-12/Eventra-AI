# ──────────────────────────────────────
# SMTP Configuration
# ──────────────────────────────────────
# For Gmail: use smtp.gmail.com / 587 and an App Password
# For Outlook: use smtp.office365.com / 587

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
