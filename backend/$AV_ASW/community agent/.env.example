# .env.example
# Copy to .env and fill in your values.
# Load with: python-dotenv or `export $(cat .env | xargs)`

# ── Ollama Configuration ──────────────────────────────────────────
# Model to use. Options: mistral, llama3, llama3:8b-instruct-q4_0, mixtral
OLLAMA_MODEL=llama3

# URL of your Ollama server (default: localhost)
OLLAMA_BASE_URL=http://localhost:11434

# ── Agent Tuning ─────────────────────────────────────────────────
# Number of subreddits to return
TOP_SUBREDDITS=5

# Number of Discord archetypes to return
TOP_DISCORD=4
